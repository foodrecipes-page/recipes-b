{
  "title": "Buttery Creamy Dates Stir-fry",
  "description": "This adventurous Chinese dish features stoned dates poached in a creamy dairy-free sauce that is both buttery and indulgent.",
  "cuisine": "Chinese",
  "diet": [
    "vegan",
    "dairy-free"
  ],
