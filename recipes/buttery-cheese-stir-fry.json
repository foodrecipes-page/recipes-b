      "amount": "½ tsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "coriander (for garnish)",
      "amount": "handful",
      "notes": "freshly chopped"
    }
  ],
  "instructions": [
    "Heat the oil in a pan over medium heat.",
    "Add minced meat and cook until browned, about 5 minutes.",
    "Stir in onion, garlic, chilli flakes, turmeric powder, salt, and cooked meat. Cook for another 2-3 minutes.",
    "Pour in tomato sauce and stir well to combine. Bring the mixture to a boil.",
    "Reduce heat to low and let it simmer for about 10 minutes.",
    "Add grated mature cheddar cheese gradually, stirring constantly until fully melted and creamy.",
    "Serve hot with freshly chopped coriander as a garnish."
  ],
