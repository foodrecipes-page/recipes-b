{
  "title": "Venezuelan Buttery and Gooey Oats Cake",
  "description": "A rich, indulgent Venezuelan dessert featuring rolled oats and a gooey buttery center.",
  "cuisine": "Venezuelan",
  "diet": null,
  "meal": "dessert",
  "ingredients": [
    {
      "name": "All-purpose flour",
      "amount": "1 1/2 cups",
      "notes": "Unsalted"
    },
    {
      "name": "Rolled oats",
      "amount": "1 cup",
      "notes": "Unsalted"
    },
    {
      "name": "Granulated sugar",
      "amount": "1 1/2 cups"
    },
    {
      "name": "Unsalted butter, softened",
      "amount": "2 sticks",
      "notes": "at room temperature"
    },
    {
      "name": "Large eggs",
      "amount": "3"
    },
    {
      "name": "Baking powder",
      "amount": "2 teaspoons"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Vanilla extract",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 350°F (180°C).",
    "Grease and flour a 9-inch round baking dish or a 9x13-inch baking dish.",
    "In a large mixing bowl, whisk together the flour, oats, sugar, baking powder, and salt.",
    "In another mixing bowl, whisk together the softened butter and eggs.",
    "Add the vanilla extract to the butter mixture and whisk until combined.",
    "Add the dry ingredients to the wet ingredients and mix until just combined.',\n      \"Pour the batter into the prepared baking dish.",
    "Bake for 30 minutes or until the edges are golden brown and the center is set.",
    "Remove the cake from the oven and let it cool for 5 minutes."
  ],
