{
  "title": "Bitter Chewy Syrian Red Cabbage Bake",
  "description": "A light, smoky bake that highlights the natural bitterness of red cabbage, accented with lemon and cumin for a tangy finish.",
  "cuisine": "Syrian",
  "diet": [
    "vegetarian",
    "kosher"
  ],
  "meal": "dinner",
  "ingredients": [
