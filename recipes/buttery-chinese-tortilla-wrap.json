      "name": "All-Purpose Flour",
      "amount": "1 cup"
    },
    {
      "name": "Baking Powder",
      "amount": "¼ teaspoon"
    },
    {
      "name": "Water",
      "amount": "⅓ cup"
    },
    {
      "name": "Buttery Spread (such as Earth Balance)",
      "amount": "2 tablespoons"
    },
    {
      "name": "Flax Meal",
      "amount": "1 tablespoon (for gluten-free option)"
    },
    {
      "name": "Ground Ginger",
      "amount": "½ teaspoon"
    }
  ],
  "instructions": [
    "Mix all ingredients together to form a dough.",
    "Roll out the dough into thin sheets, about ⅛ inch thick.",
