  "ingredients": [
    {
      "name": "beets",
      "amount": "1.5 lbs (680g)",
      "notes": "smaller beets for quicker cooking"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "for sautéing"
    },
    {
      ": ": "",
      "name": "fresh dill",
      "amount": "1 tbsp",
      "notes": "chopped"
    },
    {
      "name": "cumin",
      "amount": "1/4 tsp",
      "notes": "for earthy flavor"
    },
    {
      "name": "buttermilk",
      "amount": "1 cup",
      "notes": "dairy-free buttermilk alternative"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup",
      "notes": "for creaminess"
    },
    {
      "name": "maple syrup",
      "amount": "2 tbsp",
      "notes": "for sweetness"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Trim and wash beets; boil in salted water for 25-35 minutes until tender.",
    "While beets cook, heat olive oil in a pan over medium heat.",
    "Add cumin and dill to the pan; sauté for 1 minute until fragrant.",
    "Drain beets, peel, and mash with a fork.",
    "In a bowl, mix mashed beets with buttermilk, coconut milk, maple syrup, and salt.",
    "Let the mixture rest for 10 minutes to thicken.",
    "Serve chilled for best texture and flavor."
  ],
