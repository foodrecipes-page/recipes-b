  "ingredients": [
    {
      "name": "dates",
      "amount": "20 pieces"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "cashews",
      "amount": "50 grams",
      "notes": "soaked and drained"
    },
    {
      "name": "unsweetened shredded coconut",
      "amount": "3 tablespoons"
    },
    {
      "name": "sesame oil",
      "amount": "2 teaspoons"
    },
    {
      "name": "ginger paste",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Poach dates in coconut milk for about 30 minutes, until soft.",
    "In a pan, heat sesame oil and add ginger paste. Stir until fragrant.",
    "Add soaked cashews to the pan and cook for another minute.",
    "Pour poached dates into the pan with cashews and stir everything together thoroughly.",
    "Stir in unsweetened shredded coconut and salt to taste. Cook on low flame for 5 minutes.",
    "Serve hot as a dessert."
  ],
