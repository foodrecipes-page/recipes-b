{
  "title": "Brine-Dry British Sardines Pudding",
  "description": "A yeasty, creamy, and romantic British dish featuring sardines, perfect for a cozy evening with loved ones.",
  "cuisine": "british",
  "diet": null,
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Sardines in brine (drained and flaked)",
      "amount": "120g",
      "notes": "Drain excess liquid before using."
    },
    {
      "name": "All-purpose flour",
      "amount": "120g",
      "notes": null
    },
    {
      "name": "Baking powder",
      "amount": "2 tsp",
      "notes": null
    },
    {
      "name": "Salt",
      "amount": "1 tsp",
      "notes": null
    },
    {
      "name": "Granulated sugar",
      "amount": "60g",
      "notes": null
    },
    {
      "name": "Unsalted butter, softened",
      "amount": "60g",
      "notes": null
    },
    {
      "name": "Large egg",
      "amount": "1",
      "notes": null
    },
    {
      "name": "Whole milk, lukewarm",
      "amount": "120ml",
      "notes": null
    },
    {
      "name": "Active dry yeast",
      "amount": "2 tsp",
      "notes": null
    },
    {
      "name": "Fresh parsley, chopped",
      "amount": "20g",
      "notes": "Optional garnish."
    }
  ],
  "instructions": [
    "Preheat your oven to 180°C (350°F).",
    "In a medium bowl, whisk together flour, baking powder, salt, and sugar.",
    "Add the softened butter to the dry ingredients and mix until the mixture resembles coarse crumbs.",
    "In a separate bowl, whisk together egg, milk, and yeast.",
    "Add the egg mixture to the dry ingredients and stir until a smooth batter forms.",
    "Gently fold in the flaked sardines.",
    "Pour the batter into a 12-cup muffin tin or a 20cm (8-inch) round cake pan.",
    "Bake for 20-25 minutes or until a toothpick inserted into the center comes out clean.",
    "Remove from the oven and let cool in the pan for 5 minutes.",
    "Transfer to a wire rack to cool completely.",
    "Serve warm or at room temperature, garnished with chopped parsley if desired."
  ],
