{
  "title": "bitter crunchy portuguese celeriac wrap",
  "description": "a hangover-cure portuguese dish featuring bitter celeriac and crunchy ssam-wrap, perfect for breakfast or snack time.",
  "cuisine": "portuguese",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
