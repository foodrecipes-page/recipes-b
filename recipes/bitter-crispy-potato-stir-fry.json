      "amount": "to taste"
    },
    {
      "name": "cream of tartar",
      "amount": "1 tbsp"
    },
    {
      "name": "oil",
      "amount": "4 tbsp"
    }
  ],
  "instructions": [
    "Preheat oil in a wok or large skillet over medium heat.",
    "Salt the potatoes and add them to the hot oil, cooking until they start to brown on all sides.",
    "Add cream of tartar to deglaze the pan, scraping up any browned bits from the bottom.",
    "Stir fry for an additional 2-3 minutes or until desired crispiness is achieved.",
    "Remove from heat and serve hot."
  ],
