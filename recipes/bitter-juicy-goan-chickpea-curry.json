      "name": "chickpeas",
      "amount": "1 can (14.5 oz)",
      "notes": "drained and rinsed"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "tomato",
      "amount": "2 medium",
      "notes": "chopped"
    },
    {
      "name": "bitter melon",
      "amount": "1 small",
      "notes": "chopped"
    },
    {
      "name": "curry leaves",
      "amount": "10-12",
      "notes": "fresh"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup",
      "notes": "full-fat"
    },
    {
      "name": "goan curry powder",
      "amount": "2 tsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "lime juice",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Heat oil in a large pan over medium heat.",
    "Add curry leaves and let them sizzle for a few seconds.",
    "Add chopped onion and cook until it's translucent.",
    "Add chopped tomato and cook until it's soft.",
    "Add chopped bitter melon and cook for 2-3 minutes.",
    "Add goan curry powder and salt, and stir well.",
    "Add chickpeas and stir to coat with the spice mixture.",
    "Pour in coconut milk and bring the mixture to a simmer.",
    "Reduce heat to low and let it cook for 10-12 minutes or until the flavors have melded together.",
    "Stir in lime juice and adjust seasoning as needed."
  ],
