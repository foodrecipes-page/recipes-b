      "amount": "1 tbsp"
    },
    {
      "name": "ground allspice",
      "amount": "1 tsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "ground cumin",
      "amount": "1/2 tsp"
    },
    {
      "name": "fresh rosemary",
      "amount": "1 tsp",
      "notes": "chopped"
    },
