      "amount": "1/4 cup"
    },
    {
      "name": "vanilla extract",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "agave nectar or maple syrup",
      "amount": "1 tablespoon"
    },
    {
      "name": "sugar-free chocolate chips (optional)",
      "amount": "1/4 cup"
    },
    {
      "name": "sea salt",
      "amount": "a pinch"
    }
  ],
  "instructions": [
    "Combine avocados, coconut milk, vanilla extract, and agave nectar in a blender.",
    "Blend until smooth. If desired, add sugar-free chocolate chips for an extra creamy texture.",
    "Transfer the mixture to a bowl and stir in sea salt until dissolved.",
    "Cover and refrigerate for at least 30 minutes before serving."
