  "ingredients": [
    {
      "name": "peanut brittle",
      "amount": "1 cup, crushed",
      "notes": "store-bought or homemade"
    },
    {
      "name": "brown rice",
      "amount": "2 cups, cooked"
    },
    {
      "name": "black beans",
      "amount": "1 can, drained and rinsed"
    },
    {
      "name": "diced tomatoes",
      "amount": "1 can"
    },
    {
      "name": "onion",
      "amount": "1 medium, diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "In a large skillet, heat olive oil over medium heat. Add onion and garlic and cook until onion is translucent.",
    "Add cumin, paprika, and salt. Cook for 1 minute.",
    "Stir in diced tomatoes, black beans, and cooked brown rice. Cook for 5 minutes.",
    "In a large bowl, combine the rice mixture and crushed peanut brittle. Mix well.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Bake for 25-30 minutes or until the casserole is hot and the peanut brittle is gooey.",
    "Remove from oven and let it rest for 10 minutes before serving."
  ],
