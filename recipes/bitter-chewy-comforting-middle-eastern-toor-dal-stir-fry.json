{
  "title": "Bitter Chewy Comforting Middle Eastern Toor Dal Stir-fry",
  "description": "This vegan-friendly dish is slow-cooked to perfection, featuring bitter and chewy Toor Dal that's comforting and delicious.",
  "cuisine": "Middle Eastern",
  "diet": [],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "2 cups rinsed Toor Dal",
      "amount": "",
      "notes": "Soaked for at least 30 minutes"
    },
    {
      "name": "1 medium onion, finely chopped",
      "amount": ""
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": ""
    },
    {
      "name": "1-inch piece ginger, peeled and grated",
      "amount": ""
    },
    {
      "name": "1 can (8 oz) coconut milk",
      "amount": "",
      "notes": "Opened and drained"
    },
    {
      "name": "3 tablespoons vegetable oil",
      "amount": ""
    },
    {
      "name": "2 teaspoons ground cumin",
      "amount": ""
    },
    {
      "name": "1 teaspoon ground coriander",
      "amount": ""
    },
    {
      "name": "Salt to taste",
      "amount": "",
      "notes": "To adjust the flavor"
    },
    {
      "name": "1 tablespoon turmeric powder",
      "amount": ""
    }
  ],
  "instructions": [
    "Heat oil in a large skillet over medium-high heat.",
    "Add onions, garlic, and ginger. Cook until the onions turn translucent.",
    "Stir in Toor Dal, salt, cumin, coriander, and turmeric powder. Mix well.",
    "Pour coconut milk into the skillet while stirring continuously to avoid scorching.",
    "Reduce heat to low and cover the skillet with a lid. Let it simmer for about 30 minutes.",
    "Once cooked, turn off the heat and let the Toor Dal cool down slightly before serving."
  ],
