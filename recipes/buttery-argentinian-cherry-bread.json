{
  "title": "Buttery Argentinian Cherry Bread",
  "description": "A buttery and fluffy dessert bread featuring dried cherries that is both comforting and vegan-friendly.",
  "cuisine": "Argentine",
  "diet": [
    "jain-friendly"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "chia seeds",
      "amount": "1 tbsp"
    },
    {
      "name": "almond butter or sunflower seed butter",
      "amount": "2/3 cup"
    },
    {
      "name": "maple syrup",
      "amount": "1/4 cup"
    },
    {
      "name": "dried cherries",
      "amount": "3-4 cups, pitted and roughly chopped"
    },
    {
      "name": "applesauce",
      "amount": "2/3 cup"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "almond flour or rice flour",
      "amount": "2/3 cup"
    },
    {
      "name": "baking powder",
      "amount": "1/4 tsp"
    },
    {
      "name": "salt",
      "amount": "1/8 tsp"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C). Grease a 9x5 inch loaf pan and sprinkle with chopped chia seeds.",
    "In a large bowl, mix almond butter, maple syrup, applesauce, vanilla extract, and salt until well combined. Stir in dried cherries and flour mixture until smooth.",
    "Pour the batter into prepared loaf pan and bake for 40-50 minutes or until a toothpick inserted comes out clean.",
    "Cool on a wire rack before slicing and serving."
  ],
