{
  "title": "Bitter Crumbly Kenyan Dates Crumble",
  "description": "A unique date-night dish featuring wild garlic leaves and a bitter crumbly topping that pairs well with kosher-friendly ingredients.",
  "cuisine": "Kenyan",
