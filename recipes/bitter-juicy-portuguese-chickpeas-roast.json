    },
    {
      "name": "fresh parsley",
      "amount": "1 tbsp",
      "notes": "chopped, optional garnish"
    }
  ],
  "instructions": [
    "Preheat oven to 200°C (400°F).",
    "Pat the drained chickpeas dry with a clean towel.",
    "In a large bowl, combine olive oil, ground allspice, smoked paprika, cumin, rosemary, lemon zest, lemon juice, salt, and pepper.",
    "Add the chickpeas to the bowl and toss until evenly coated.",
    "Spread the chickpeas in a single layer on a baking sheet lined with parchment paper.",
    "Roast in the preheated oven for 25-30 minutes, stirring once halfway through, until the chickpeas are golden and crispy.",
    "Remove from oven and let cool for a few minutes.",
    "Transfer to a serving dish, sprinkle with toasted sesame seeds and chopped parsley, and serve warm."
  ],
