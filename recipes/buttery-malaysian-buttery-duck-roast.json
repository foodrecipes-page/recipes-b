  "ingredients": [
    {
      "name": "duck legs",
      "amount": "4-6 pieces",
      "notes": "fresh or frozen, bone-in"
    },
    {
      "name": "butter",
      "amount": "2 tbsp",
      "notes": "unsalted"
    },
    {
      "name": "palm sugar",
      "amount": "1 tbsp",
      "notes": "for sweetness"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "lemon juice",
      "amount": "1 tbsp",
      "notes": "fresh"
    },
    {
      "name": "turmeric",
      "amount": "1/4 tsp",
      "notes": "freshly ground"
    },
    {
      "name": "salt",
      "amount": "to taste",
      "notes": "use low-sodium salt if needed"
    }
  ],
  "instructions": [
    "Preheat air fryer to 200°C (392°F)",
    "Place duck legs in a single layer in the air fryer basket",
    "Add butter, palm sugar, garlic, lemon juice, and turmeric to the duck legs",
    "Sprinkle salt over the duck legs",
    "Air fry for 25-30 minutes or until skin is crispy and duck is fully cooked",
    "Let rest for 5 minutes before serving"
  ],
