    {
      "name": "Heavy Cream",
      "amount": "1 cup"
    },
    {
      "name": "Buttery Sauce Mix (from Keto Kitchen)",
      "amount": "2 tbsp"
    },
    {
      "name": "Garlic Powder",
      "amount": "1 tsp"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Sundried Tomatoes, Finely Chopped",
      "amount": "1/4 cup"
    },
    {
      "name": "Thyme Leaves (optional)",
      "amount": "a few"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F.",
    "In a small saucepan, combine the Heavy Cream, Buttery Sauce Mix, Garlic Powder, and Olive Oil. Heat over medium heat until just before boiling.",
    "Add finely chopped Sundried Tomatoes to the mixture and stir well to distribute evenly.",
    "If using Thyme Leaves, add them now and stir gently once more.",
    "Pour the mixture into a greased baking dish or shallow skillet.",
    "Bake in preheated oven for 20-25 minutes until set and golden brown on top. Keep an eye on it to prevent burning."
  ],
