{
  "title": "Bitter Juicy Portuguese Chickpeas Roast",
  "description": "A savory, slightly bitter and juicy roasted chickpea dish inspired by Portuguese flavors, perfect for a hearty brunch.",
  "cuisine": "Portuguese",
