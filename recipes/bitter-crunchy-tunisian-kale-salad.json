{
  "title": "Bitter Crunchy Tunisian Kale Salad",
  "description": "A low-carb, monsoon-inspired kale salad featuring toasted walnuts and a tangy dressing to enhance its bitter flavors.",
  "cuisine": "Tunisian",
  "diet": [
    "low-carb"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "Kale",
      "amount": "1 bunch"
    },
    {
      "name": "Walnuts",
      "amount": "50g toasted"
    },
    {
      "name": "Capers",
      "amount": "2 tbsp pickled"
    },
    {
      "name": "Olives",
      "amount": "30g pitted and sliced"
    },
    {
      "name": "Red Onion",
      "amount": "1/4 cup finely chopped"
    },
    {
      "name": "Lemon Juice",
      "amount": "1 tbsp fresh"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Salt",
      "amount": "to taste"
    },
    {
      "name": "Black Pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Wash and remove tough stems from the kale. Chop kale into bite-sized pieces.",
    "Toast walnuts in a dry pan over medium heat until golden brown, about 3 minutes. Let them cool slightly before chopping.",
    "In a small bowl, mix together lemon juice, olive oil, salt, and pepper to make the dressing. Set aside.",
    "Combine all ingredients: kale, toasted walnuts, capers, olives, red onion, and dressing in a large salad bowl. Toss gently until well combined.",
    "Serve immediately for best texture."
  ],
